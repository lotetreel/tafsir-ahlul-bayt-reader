{
  "hosting": {
    "target": "reader",
    "public": "deploy",
    "predeploy": [
      "node scripts/prepare-hosting.js"
    ],
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "README.md",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
